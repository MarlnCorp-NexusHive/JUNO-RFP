# ===========================================
# AI SERVICE CONFIGURATION
# ===========================================

# OpenRouter API (Primary Provider)
VITE_OPENROUTE_API_KEY=your_openroute_api_key_here
VITE_OPENROUTE_BASE_URL=https://openrouter.ai/api/v1
VITE_OPENROUTE_MODEL=openai/gpt-4o-mini

# Hugging Face API (Fallback Provider)
VITE_HUGGINGFACE_API_KEY=your_huggingface_token_here
VITE_HUGGINGFACE_MODEL=microsoft/DialoGPT-medium
VITE_API_TIMEOUT=30000


# API Configuration
VITE_API_TIMEOUT=30000
VITE_MAX_RETRIES=3
VITE_STREAMING_ENABLED=true