VITE_FMP_API_KEY=

# API base (production / preview builds). Leave unset in dev to use Vite proxy → juno-backend.
# VITE_API_URL=http://localhost:3000

# Where Vite should forward API routes in dev (default: juno-backend on 3000).
# VITE_BACKEND_PROXY_TARGET=http://127.0.0.1:3000
