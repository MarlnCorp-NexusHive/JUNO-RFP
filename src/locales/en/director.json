  "faqItems": {
    "passwordReset": {
      "question": "How do I reset my password?",
      "answer": "Click on 'Forgot Password' on the login page, enter your email, and follow the instructions sent to your inbox."
    },
    "itSupport": {
      "question": "How do I contact IT support?",
      "answer": "You can reach IT support via email at support@univ.edu or call +1 (555) 123-4567 during business hours."
    },
    "complianceReports": {
      "question": "How do I generate compliance reports?",
      "answer": "Navigate to Reports > Compliance in the main menu, select your criteria, and click 'Generate Report'."
    },
    "dataExport": {
      "question": "How do I export my data?",
      "answer": "Go to Settings > Data Management > Export, choose your data range, and select the export format."
    },
    "userPermissions": {
      "question": "How do I manage user permissions?",
      "answer": "As a director, you can manage permissions in User Management > Roles & Permissions section."
    }
  },
